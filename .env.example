# Bala Travel Agent — Environment Variables
# Copy this to .env and fill in your values

# Amadeus API (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# SerpAPI for Google Flights (https://serpapi.com)
SERPAPI_API_KEY=your_serpapi_key

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key

# App authentication
APP_PASSWORD=your_chosen_password

# Session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change_me_to_random_hex_string

# Environment
ENVIRONMENT=development
